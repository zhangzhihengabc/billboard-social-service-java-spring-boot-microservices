# ============================================================
# Billboard Social Service — Environment Variables
# Copy to .env and fill in production values
# ============================================================

# --- Database ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/billboard_social
DB_USERNAME=billboard_user
DB_PASSWORD=                              # REQUIRED in production

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=103.95.132.102:9092
KAFKA_USERNAME=admin
KAFKA_PASSWORD=                           # REQUIRED in production
KAFKA_CONSUMER_GROUP=billboard-social-service
APP_KAFKA_TOPIC=social-events

# --- Eureka ---
EUREKA_CLIENT_SERVICE_URL_DEFAULTZONE=https://eurekauser:EurekaPass2026!@eureka.pineapps.online/eureka/

# --- Config Server (optional) ---
CONFIG_SERVER_URI=http://localhost:8888

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Security ---
JWT_SECRET=                               # REQUIRED in production
INTERNAL_API_KEY=                          # REQUIRED in production

# --- Server ---
SERVER_PORT=8082
SERVER_CONTEXT_PATH=/social

# --- External Services ---
ESPORTS_BACKEND_URL=http://localhost:8084

# --- App Settings ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
MAIL_FROM=uditmehta100@gmail.com
APP_BASE_URL=http://localhost:3000
FRIENDS_FINDER_SUGGESTION_CRON=0 0 3 * * *
FRIENDS_FINDER_LOOKBACK_DAYS=30
FRIENDS_FINDER_PURGE_DAYS=60
